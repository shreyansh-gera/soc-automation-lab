#!/usr/bin/env python3
import sys, json, urllib.request, ssl

alert_file = sys.argv[1]
with open(alert_file) as f:
    alert = json.load(f)

url = "YOUR_DISCORD_WEBHOOK_URL_HERE"

level = alert.get("rule", {}).get("level", "?")
desc = alert.get("rule", {}).get("description", "?")
agent = alert.get("agent", {}).get("name", "?")

msg = {"content": f"🚨 **Wazuh Alert** | Level {level}\n**{desc}**\nAgent: `{agent}`"}

req = urllib.request.Request(url, json.dumps(msg).encode(), {"Content-Type": "application/json", "User-Agent": "DiscordBot (https://discord.com, 1.0)"}, method="POST")
ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE
urllib.request.urlopen(req, context=ctx, timeout=10)
